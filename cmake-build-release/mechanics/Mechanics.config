<?xml version="1.0" ?>
 <arcane-config code-name="Mechanics">
  <time-loops>
    <time-loop name="MechanicsLoop">
      <title>Mechanics</title>
      <description>Default timeloop for code Mechanics</description>

      <modules>
        <module name="Mechanics" need="required" />
        <module name="ArcanePostProcessing" need="required" />
      </modules>

      <entry-points where="init">
        <entry-point name="Mechanics.StartInit" />
      </entry-points>
      <entry-points where="compute-loop">
        <entry-point name="Mechanics.Compute" />
      </entry-points>
    </time-loop>
  </time-loops>
</arcane-config>
